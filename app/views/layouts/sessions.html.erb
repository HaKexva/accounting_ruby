<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <title><%= content_for(:title) || "登入 · 記帳" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="app-main-gradient min-h-dvh overflow-x-hidden bg-background text-foreground antialiased">
    <main class="flex min-h-dvh flex-col items-center justify-center px-4 py-10 sm:px-6">
      <% if flash[:alert].present? || flash[:notice].present? %>
        <div class="mb-6 w-full max-w-sm shrink-0 space-y-2">
          <% if flash[:alert].present? %>
            <div class="rounded-xl border border-red-500/30 bg-red-500/[0.08] px-4 py-3 text-center text-sm font-medium leading-snug text-red-900 dark:text-red-100">
              <%= flash[:alert] %>
            </div>
          <% end %>
          <% if flash[:notice].present? %>
            <div class="rounded-xl border border-emerald-500/35 bg-emerald-500/[0.08] px-4 py-3 text-center text-sm font-medium leading-snug text-emerald-900 dark:text-emerald-100">
              <%= flash[:notice] %>
            </div>
          <% end %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
