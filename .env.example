# Google OAuth (production / optional local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. If unset, production uses https://<APP_HOST>/auth/google_oauth2/callback
# Local: http://localhost:3000/auth/google_oauth2/callback
# Do NOT copy localhost here on Railway — use APP_HOST instead.
# GOOGLE_OAUTH_REDIRECT_URI=

# Production hostname only (no https://): e.g. accounting-ruby-production.up.railway.app
# Must match the URL you open in the browser. Also add the callback URL in Google Cloud Console.
APP_HOST=
