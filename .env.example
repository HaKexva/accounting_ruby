# Google OAuth (production / optional local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match an "Authorized redirect URI" in Google Cloud Console exactly.
# Local default: http://localhost:3000/auth/google_oauth2/callback
# If you open the app as http://127.0.0.1:3000, add that URI in Console too, or use localhost only.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google_oauth2/callback

# Production app host (e.g. your-app.up.railway.app) — used if GOOGLE_OAUTH_REDIRECT_URI is unset
APP_HOST=
